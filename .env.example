# ============================================================
# Invoice Workflow Agent POC — Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values.
# Never commit .env to version control.

# ── OpenAI ──────────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key-here

# Model to use (gpt-4o recommended, gpt-4o-mini for cost savings)
OPENAI_MODEL=gpt-4o

# ── Workflow Settings ────────────────────────────────────────
# Invoice amount (INR) above which human approval is required
APPROVAL_THRESHOLD=100000

# ── Tracing ─────────────────────────────────────────────────
# Set to "true" to enable full SDK execution tracing
ENABLE_TRACING=true

# Directory where output logs and traces are saved
OUTPUT_DIR=output
